{
  "name": "oracle-arena",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present && (cp -r packages/web/dist dist || xcopy /E /I packages\\web\\dist dist)",
    "test": "npm run test --workspaces --if-present",
    "dev:web": "npm run dev --workspace=packages/web",
    "start:agent": "npm run start --workspace=packages/cli"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
